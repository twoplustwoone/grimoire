{
  "name": "@grimoire/db",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "generate": "prisma generate --schema=./prisma/schema.prisma",
    "migrate": "prisma migrate dev --schema=./prisma/schema.prisma",
    "seed": "node --env-file=.env --import tsx/esm src/seed.ts"
  },
  "dependencies": {
    "@prisma/adapter-pg": "latest",
    "@prisma/client": "latest",
    "pg": "latest"
  },
  "devDependencies": {
    "@types/pg": "latest",
    "dotenv": "latest",
    "prisma": "latest",
    "tsx": "^4.21.0"
  }
}
