// schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ==================== AUTH ====================

model User {
  id               String   @id @default(cuid())
  email            String   @unique
  name             String?
  image            String?
  emailVerified    Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  memberships      CampaignMembership[]
  notes            Note[]
  changelogEntries ChangelogEntry[]
  sessions         Session[] @relation("UserSessions")
  accounts         Account[]           @relation("UserAccounts")
  entityReveals    EntityReveal[]
  apiKeys          ApiKey[]
  oauthCodes         OAuthAuthorizationCode[]
  oauthAccessTokens  OAuthAccessToken[]
  oauthRefreshTokens OAuthRefreshToken[]
  playerCharacters   PlayerCharacter[]
  journals           Journal[]
}

// ==================== CAMPAIGN ====================

model Campaign {
  id          String         @id @default(cuid())
  name        String
  description String?
  status      CampaignStatus @default(ACTIVE)
  settings    Json?
  isDemo      Boolean        @default(false)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  memberships      CampaignMembership[]
  customFieldDefs  CustomFieldDefinition[]
  inWorldDates     InWorldDate[]
  relationships    Relationship[]
  reveals          EntityReveal[]
  invites          CampaignInvite[]
  linkedJournals   Journal[]
}

enum OwnerType {
  CAMPAIGN
  JOURNAL
}

enum CampaignStatus {
  ACTIVE
  PAUSED
  COMPLETED
  ARCHIVED
}

// ==================== JOURNAL ====================

model Journal {
  id               String    @id @default(cuid())
  ownerId          String
  owner            User      @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  linkedCampaignId String?
  linkedCampaign   Campaign? @relation(fields: [linkedCampaignId], references: [id], onDelete: SetNull)
  name             String
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  deletedAt        DateTime?

  @@index([ownerId])
  @@index([linkedCampaignId])
}

model CampaignMembership {
  id         String     @id @default(cuid())
  campaignId String
  userId     String
  role       MemberRole @default(PLAYER)
  createdAt  DateTime   @default(now())

  campaign         Campaign                @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  user             User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  nodeReveals      InformationNodeReveal[]

  @@unique([campaignId, userId])
}

enum MemberRole {
  GM
  CO_GM
  PLAYER
}

// ==================== SESSIONS ====================

model GameSession {
  id         String        @id @default(cuid())
  ownerType  OwnerType
  ownerId    String
  title      String?
  number     Int
  playedOn   DateTime?
  gmSummary  String?
  summaryMentions Json?
  aiSummary  String?
  status     SessionStatus @default(PLANNED)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  inWorldDates SessionInWorldDate[]
  entityTags   SessionEntityTag[]
  clues        Clue[]
  worldEvents  WorldEvent[]

  @@unique([ownerType, ownerId, number])
  @@map("Session")
}

enum SessionStatus {
  PLANNED
  COMPLETED
}

model SessionInWorldDate {
  id            String @id @default(cuid())
  sessionId     String
  inWorldDateId String

  session     GameSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  inWorldDate InWorldDate @relation(fields: [inWorldDateId], references: [id], onDelete: Cascade)

  @@unique([sessionId, inWorldDateId])
}

model SessionEntityTag {
  id         String     @id @default(cuid())
  sessionId  String
  entityType EntityType
  entityId   String

  session GameSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, entityType, entityId])
  @@index([entityType, entityId])
}

// ==================== IN-WORLD CALENDAR ====================

model InWorldDate {
  id         String   @id @default(cuid())
  campaignId String
  label      String
  sortOrder  Int
  createdAt  DateTime @default(now())

  campaign    Campaign             @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  sessions    SessionInWorldDate[]
  worldEvents WorldEvent[]
}

// ==================== ENTITIES ====================

model NPC {
  id          String       @id @default(cuid())
  ownerType   OwnerType
  ownerId     String
  name        String
  description String?
  status      EntityStatus @default(ACTIVE)
  locationId  String?
  deletedAt   DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  location           Location?           @relation(fields: [locationId], references: [id])
  factionMemberships FactionMembership[]

  @@index([ownerType, ownerId])
}

model PlayerCharacter {
  id           String                @id @default(cuid())
  ownerType    OwnerType
  ownerId      String
  linkedUserId String?
  name         String
  description  String?
  status       PlayerCharacterStatus @default(ACTIVE)
  externalUrl  String?
  deletedAt    DateTime?
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt

  linkedUser User? @relation(fields: [linkedUserId], references: [id], onDelete: SetNull)
  invites    CampaignInvite[]

  @@index([ownerType, ownerId])
  @@index([linkedUserId])
}

enum PlayerCharacterStatus {
  ACTIVE
  RETIRED
  DECEASED
}

model Location {
  id          String       @id @default(cuid())
  ownerType   OwnerType
  ownerId     String
  name        String
  description String?
  status      EntityStatus @default(ACTIVE)
  parentId    String?
  deletedAt   DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  parent   Location?  @relation("LocationHierarchy", fields: [parentId], references: [id])
  children Location[] @relation("LocationHierarchy")
  npcs     NPC[]

  @@index([ownerType, ownerId])
}

model Faction {
  id          String       @id @default(cuid())
  ownerType   OwnerType
  ownerId     String
  name        String
  description String?
  agenda      String?
  status      EntityStatus @default(ACTIVE)
  deletedAt   DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  memberships FactionMembership[]

  @@index([ownerType, ownerId])
}

model FactionMembership {
  id        String  @id @default(cuid())
  factionId String
  npcId     String
  role      String?

  faction Faction @relation(fields: [factionId], references: [id], onDelete: Cascade)
  npc     NPC     @relation(fields: [npcId], references: [id], onDelete: Cascade)

  @@unique([factionId, npcId])
}

model Thread {
  id           String        @id @default(cuid())
  ownerType    OwnerType
  ownerId      String
  title        String
  description  String?
  status       ThreadStatus  @default(OPEN)
  urgency      ThreadUrgency @default(MEDIUM)
  resolvedNote String?
  deletedAt    DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  entityTags ThreadEntityTag[]

  @@index([ownerType, ownerId])
}

enum ThreadStatus {
  OPEN
  RESOLVED
  DORMANT
}

enum ThreadUrgency {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model ThreadEntityTag {
  id         String     @id @default(cuid())
  threadId   String
  entityType EntityType
  entityId   String

  thread Thread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@unique([threadId, entityType, entityId])
  @@index([entityType, entityId])
}

model Clue {
  id                    String    @id @default(cuid())
  ownerType             OwnerType
  ownerId               String
  title                 String
  description           String?
  discoveredInSessionId String?
  deletedAt             DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  discoveredInSession GameSession? @relation(fields: [discoveredInSessionId], references: [id])

  @@index([ownerType, ownerId])
}

model WorldEvent {
  id            String    @id @default(cuid())
  ownerType     OwnerType
  ownerId       String
  title         String
  description   String?
  inWorldDateId String?
  sessionId     String?
  createdAt     DateTime  @default(now())

  inWorldDate InWorldDate? @relation(fields: [inWorldDateId], references: [id])
  session     GameSession? @relation(fields: [sessionId], references: [id])

  @@index([ownerType, ownerId])
}

enum EntityStatus {
  ACTIVE
  INACTIVE
  DEAD
  DESTROYED
  RETIRED
}

enum EntityType {
  NPC
  PLAYER_CHARACTER
  LOCATION
  FACTION
  THREAD
  CLUE
  WORLD_EVENT
  SESSION
  MEMBERSHIP
}

// ==================== CROSS-CUTTING ====================

model Note {
  id         String     @id @default(cuid())
  entityType EntityType
  entityId   String
  campaignId String
  sessionId  String?
  authorId   String
  content    Json
  mentions   Json?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  author User @relation(fields: [authorId], references: [id])

  @@index([entityType, entityId])
  @@index([campaignId])
  @@index([sessionId])
}

model InformationNode {
  id         String         @id @default(cuid())
  entityType EntityType
  entityId   String
  campaignId String
  title      String
  content    String
  visibility NodeVisibility @default(GM_ONLY)
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  revealedTo InformationNodeReveal[]

  @@index([entityType, entityId])
  @@index([campaignId])
}

enum NodeVisibility {
  GM_ONLY
  ALL_PLAYERS
  SPECIFIC_PLAYERS
}

model InformationNodeReveal {
  id                String   @id @default(cuid())
  informationNodeId String
  membershipId      String
  revealedAt        DateTime @default(now())

  informationNode InformationNode    @relation(fields: [informationNodeId], references: [id], onDelete: Cascade)
  membership      CampaignMembership @relation(fields: [membershipId], references: [id], onDelete: Cascade)

  @@unique([informationNodeId, membershipId])
}

model Relationship {
  id            String     @id @default(cuid())
  campaignId    String
  entityTypeA   EntityType
  entityIdA     String
  entityTypeB   EntityType
  entityIdB     String
  label         String
  description   String?
  bidirectional Boolean    @default(false)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([entityTypeA, entityIdA])
  @@index([entityTypeB, entityIdB])
  @@index([campaignId])
}

model ChangelogEntry {
  id         String     @id @default(cuid())
  entityType EntityType
  entityId   String
  campaignId String
  sessionId  String?
  authorId   String?
  field      String
  oldValue   String?
  newValue   String?
  note       String?
  createdAt  DateTime   @default(now())

  author User? @relation(fields: [authorId], references: [id])

  @@index([entityType, entityId])
  @@index([campaignId])
  @@index([sessionId])
}

model EntityReveal {
  id                 String     @id @default(cuid())
  campaignId         String
  entityType         EntityType
  entityId           String
  userId             String?
  displayName        String?
  displayDescription String?
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  user     User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([entityType, entityId, userId])
  @@index([campaignId])
  @@index([userId])
}

model CampaignInvite {
  id         String     @id @default(cuid())
  campaignId String
  email      String
  token      String     @unique @default(cuid())
  role       MemberRole @default(PLAYER)
  pcId       String?
  expiresAt  DateTime
  acceptedAt DateTime?
  createdAt  DateTime   @default(now())

  campaign Campaign         @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  pc       PlayerCharacter? @relation(fields: [pcId], references: [id], onDelete: SetNull)

  @@index([campaignId])
  @@index([token])
}

model ApiKey {
  id         String    @id @default(cuid())
  userId     String
  name       String    @default("My API Key")
  keyHash    String    @unique
  keyPrefix  String
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())
  expiresAt  DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model OAuthClient {
  id                      String   @id @default(cuid())
  clientId                String   @unique
  clientSecretHash        String?
  clientName              String
  redirectUris            String[]
  grantTypes              String[] @default(["authorization_code", "refresh_token"])
  tokenEndpointAuthMethod String   @default("none")
  createdAt               DateTime @default(now())
}

model OAuthAuthorizationCode {
  id                  String   @id @default(cuid())
  code                String   @unique
  clientId            String
  userId              String
  redirectUri         String
  scope               String?
  codeChallenge       String
  codeChallengeMethod String   @default("S256")
  expiresAt           DateTime
  createdAt           DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([code])
}

model OAuthAccessToken {
  id        String   @id @default(cuid())
  token     String   @unique
  clientId  String
  userId    String
  scope     String?
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
}

model OAuthRefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  clientId  String
  userId    String
  scope     String?
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
}

// ==================== CUSTOM FIELDS ====================

model CustomFieldDefinition {
  id           String          @id @default(cuid())
  campaignId   String
  targetEntity EntityType
  name         String
  fieldType    CustomFieldType
  config       Json?
  displayAs    String?
  sortOrder    Int             @default(0)
  createdAt    DateTime        @default(now())

  campaign Campaign           @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  values   CustomFieldValue[]

  @@unique([campaignId, targetEntity, name])
}

enum CustomFieldType {
  TEXT
  NUMBER
  BOOLEAN
  SELECT
  MULTI_SELECT
  PROGRESS
}

model CustomFieldValue {
  id           String     @id @default(cuid())
  definitionId String
  entityType   EntityType
  entityId     String
  value        String
  updatedAt    DateTime   @updatedAt

  definition CustomFieldDefinition @relation(fields: [definitionId], references: [id], onDelete: Cascade)

  @@unique([definitionId, entityId])
  @@index([entityType, entityId])
}

// ==================== BETTER AUTH ====================

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime
  updatedAt DateTime
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation("UserSessions", fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation("UserAccounts", fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime
  updatedAt             DateTime

  @@map("account")
}

model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime?
  updatedAt  DateTime?

  @@map("verification")
}
