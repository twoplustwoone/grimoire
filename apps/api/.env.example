# Postgres connection string. Local dev uses the Docker compose service.
DATABASE_URL="postgresql://grimoire:grimoire@localhost:5432/grimoire"

# Port the API listens on. Matches apps/web's default API_INTERNAL_URL.
PORT=3005

# Origin of the web app — used for CORS, Better Auth trusted origins,
# the OAuth issuer, and invite links emailed to players.
WEB_URL="http://localhost:3000"

# Better Auth baseURL. The API mounts Better Auth at /api/auth/*; this
# is the absolute URL Better Auth uses to build cookies and redirects.
BETTER_AUTH_URL="http://localhost:3005"

# Session signing secret. Generate with `openssl rand -hex 32`.
BETTER_AUTH_SECRET=""

# Claude API key for session recap generation.
# Get one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=""
