# Postgres connection string. Server components read from Prisma directly
# via @grimoire/db, so the web app needs DATABASE_URL too.
DATABASE_URL="postgresql://grimoire:grimoire@localhost:5432/grimoire"

# Internal URL the Next.js server uses to proxy /api/v1/*, /mcp, and the
# OAuth endpoints to the Hono API. Must match the API's PORT.
API_INTERNAL_URL="http://localhost:3005"

# Better Auth baseURL. Must match the API's BETTER_AUTH_URL.
BETTER_AUTH_URL="http://localhost:3005"

# Session signing secret. Must match the API's BETTER_AUTH_SECRET.
# Generate with `openssl rand -hex 32`.
BETTER_AUTH_SECRET=""

# Client-side base URL fallback used only in SSR paths where `window` is
# undefined. Browser code reads window.location.origin instead.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Controls Prisma query logging and other dev/prod toggles in @grimoire/db.
NODE_ENV=development
